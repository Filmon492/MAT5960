@online{nittiAsymptoticallyCompatibleEntropyconsistent2025,
  title       = {Asymptotically Compatible Entropy-Consistent Discretization for a Class of Nonlocal Conservation Laws},
  author      = {Nitti, Nicola De and Huang, Kuang},
  date        = {2025-09-30},
  eprint      = {2510.00221},
  eprinttype  = {arXiv},
  eprintclass = {math},
  doi         = {10.48550/arXiv.2510.00221},
  url         = {http://arxiv.org/abs/2510.00221},
  urldate     = {2026-05-11},
  abstract    = {We consider a class of nonlocal conservation laws modeling traffic flows, given by \$ \textbackslash partial\_t ρ\_\textbackslash varepsilon + \textbackslash partial\_x(V(ρ\_\textbackslash varepsilon \textbackslash ast γ\_\textbackslash varepsilon) ρ\_\textbackslash varepsilon) = 0 \$ with a suitable convex kernel \$ γ\_\textbackslash varepsilon \$, and its Godunov-type numerical discretization. We prove that, as the nonlocal parameter \$ \textbackslash varepsilon \$ and mesh size \$ h \$ tend to zero simultaneously, the discrete approximation \$ W\_\{\textbackslash varepsilon,h\} \$ of \$ W\_\textbackslash varepsilon := ρ\_\textbackslash varepsilon \textbackslash ast γ\_\textbackslash varepsilon \$ converges to the entropy solution of the (local) scalar conservation law \$ \textbackslash partial\_t ρ+ \textbackslash partial\_x(V(ρ) ρ) = 0 \$, with an explicit convergence rate estimate of order \$ \textbackslash varepsilon+h+\textbackslash sqrt\{\textbackslash varepsilon\textbackslash, t\}+\textbackslash sqrt\{h\textbackslash,t\} \$. In particular, with an exponential kernel, we establish the same convergence result for the discrete approximation \$ ρ\_\{\textbackslash varepsilon,h\} \$ of \$ ρ\_\textbackslash varepsilon \$, along with an \$ \textbackslash mathrm\{L\}\textasciicircum 1 \$-contraction property for \$ W\_\textbackslash varepsilon \$. The key ingredients in proving these results are uniform \$ \textbackslash mathrm\{L\}\textasciicircum\textbackslash infty \$- and \$\textbackslash mathrm\{TV\}\$-estimates that ensure compactness of approximate solutions, and discrete entropy inequalities that ensure the entropy admissibility of the limit solution.},
  pubstate    = {prepublished},
  keywords    = {Mathematics - Analysis of PDEs,Mathematics - Numerical Analysis},
  file        = {/Users/filmontesfamikael/Zotero/storage/GKFZ3L2I/Nitti og Huang - 2025 - Asymptotically compatible entropy-consistent discretization for a class of nonlocal conservation law.pdf;/Users/filmontesfamikael/Zotero/storage/YEVAI3AU/2510.html},
}

@article{colomboLocalLimitNonlocal2021,
  title        = {Local Limit of Nonlocal Traffic Models: Convergence Results and Total Variation Blow-Up},
  shorttitle   = {Local Limit of Nonlocal Traffic Models},
  author       = {Colombo, Maria and Crippa, Gianluca and Marconi, Elio and Spinolo, Laura V.},
  date         = {2021-10},
  journaltitle = {Annales de l'Institut Henri Poincaré C, Analyse non linéaire},
  shortjournal = {Ann. Inst. H. Poincaré C Anal. Non Linéaire},
  volume       = {38},
  number       = {5},
  eprint       = {1808.03529},
  eprinttype   = {arXiv},
  eprintclass  = {math},
  pages        = {1653--1666},
  issn         = {0294-1449, 1873-1430},
  doi          = {10.1016/j.anihpc.2020.12.002},
  url          = {http://arxiv.org/abs/1808.03529},
  urldate      = {2026-05-11},
  abstract     = {Consider a nonlocal conservation where the flux function depends on the convolution of the solution with a given kernel. In the singular local limit obtained by letting the convolution kernel converge to the Dirac delta one formally recovers a conservation law. However, recent counter-examples show that in general the solutions of the nonlocal equations do not converge to a solution of the conservation law. In this work we focus on nonlocal conservation laws modeling vehicular traffic: in this case, the convolution kernel is anisotropic. We show that, under fairly general assumptions on the (anisotropic) convolution kernel, the nonlocal-to-local limit can be rigorously justified provided the initial datum satisfies a one-sided Lipschitz condition and is bounded away from \$0\$. We also exhibit a counter-example showing that, if the initial datum attains the value \$0\$, then there are severe obstructions to a convergence proof.},
  keywords     = {Mathematics - Analysis of PDEs},
  file         = {/Users/filmontesfamikael/Zotero/storage/JERV8WKP/Colombo et al. - 2021 - Local limit of nonlocal traffic models convergence results and total variation blow-up.pdf;/Users/filmontesfamikael/Zotero/storage/3KFLXSD4/1808.html},
}

