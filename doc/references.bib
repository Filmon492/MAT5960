@article{bressanTrafficFlowNonlocal2020,
  title        = {On {{Traffic Flow}} with {{Nonlocal Flux}}: {{A Relaxation Representation}}},
  shorttitle   = {On {{Traffic Flow}} with {{Nonlocal Flux}}},
  author       = {Bressan, Alberto and Shen, Wen},
  date         = {2020-09-01},
  journaltitle = {Archive for Rational Mechanics and Analysis},
  shortjournal = {Arch Rational Mech Anal},
  volume       = {237},
  number       = {3},
  pages        = {1213--1236},
  issn         = {1432-0673},
  doi          = {10.1007/s00205-020-01529-z},
  url          = {https://doi.org/10.1007/s00205-020-01529-z},
  urldate      = {2026-04-26},
  abstract     = {We consider a conservation law model of traffic flow, where the velocity of each car depends on a weighted average of the traffic density \$\$\textbackslash rho \$\$ahead. The averaging kernel is of exponential type: \$\$w\_\textbackslash varepsilon (s)=\textbackslash varepsilon \textasciicircum\{-1\} e\textasciicircum\{-s/\textbackslash varepsilon \}\$\$. By a transformation of coordinates, the problem can be reformulated as a \$\$2\textbackslash times 2\$\$hyperbolic system with relaxation. Uniform BV bounds on the solution are thus obtained, independent of the scaling parameter \$\$\textbackslash varepsilon \$\$. Letting \$\$\textbackslash varepsilon \textbackslash rightarrow 0\$\$, the limit yields a weak solution to the corresponding conservation law \$\$\textbackslash rho \_t + ( \textbackslash rho v(\textbackslash rho ))\_x=0\$\$. In the case where the velocity \$\$v(\textbackslash rho )= a-b\textbackslash rho \$\$is affine, using the Hardy–Littlewood rearrangement inequality we prove that the limit is the unique entropy-admissible solution to the scalar conservation law.},
  langid       = {english},
  file         = {/Users/filmontesfamikael/Zotero/storage/38W4I946/Bressan og Shen - 2020 - On Traffic Flow with Nonlocal Flux A Relaxation Representation.pdf},
}


